# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, and set the same
# variables in your Vercel Project → Settings → Environment Variables
# for production.
# ─────────────────────────────────────────────────────────────

# Postgres connection string.
#   • Local dev: a local Postgres or a free Neon branch.
#   • Production: created for you when you add Vercel Postgres to the project
#     (Vercel injects POSTGRES_URL automatically — you don't set it by hand there).
POSTGRES_URL="postgres://user:password@host:5432/lifstyl"

# Vercel Blob store token (image uploads for the carousel / staff / testimonials).
#   • Production: injected automatically when you add a Blob store to the project.
#   • Local dev: copy the token from the Blob store's "Quickstart" tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ── Admin login (single admin) ──────────────────────────────
# The email you'll log into /admin with.
ADMIN_EMAIL="you@lifstyl.online"
# A bcrypt hash of your admin password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'YourPasswordHere'
#
# IMPORTANT (local .env only): Next.js runs dotenv-expand on this file, which
# treats "$" as a variable reference and will corrupt the hash. In a LOCAL
# .env, escape every "$" as "\$", e.g.  \$2a\$10\$abc...  — Vercel's dashboard
# env vars are literal and need NO escaping (paste the raw hash there).
ADMIN_PASSWORD_HASH="\$2a\$10\$replace_this_with_a_real_bcrypt_hash"

# ── Auth.js ─────────────────────────────────────────────────
# A random secret used to sign the session cookie. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="replace_with_a_long_random_string"
